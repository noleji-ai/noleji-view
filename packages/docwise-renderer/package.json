{
  "name": "@docwise/renderer",
  "version": "1.0.0",
  "description": "Standalone markdown rendering, styling, and export pipeline extracted from docwise",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "unified": "^11.0.0",
    "remark-parse": "^11.0.0",
    "remark-gfm": "^4.0.0",
    "remark-rehype": "^11.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-highlight": "^7.0.0",
    "rehype-stringify": "^10.0.0",
    "jspdf": "^4.0.0",
    "html2canvas": "^1.4.0"
  },
  "keywords": ["markdown", "renderer", "pdf", "html", "docwise"],
  "license": "MIT"
}
