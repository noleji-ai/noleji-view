# Supabase
# For real login, create app/.env.local from this file and set a live project URL + anon key.
# Email/password login works immediately after this. OAuth additionally needs redirect URLs/provider setup.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Billing
# Keep `manual` until your Noleji-owned Toss Payments flow URLs and webhook /
# entitlement sync are configured. The app fails closed when Toss is selected
# without these values so users are never sent into a half-wired billing flow.
VITE_BILLING_PROVIDER=manual
VITE_TOSS_CLIENT_KEY=test_gck_your_toss_client_key
VITE_TOSS_MONTHLY_FLOW_URL=https://billing.noleji.ai/toss/monthly
VITE_TOSS_LIFETIME_FLOW_URL=https://billing.noleji.ai/toss/lifetime
